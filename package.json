{
  "name": "offline-pdf-toolkit",
  "version": "1.0.0",
  "description": "Privacy-first offline PDF toolkit desktop application built with Electron and React.",
  "main": "dist-electron/electron-main/main.js",
  "author": "OpenAI Codex",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:main\" \"npm:dev:electron\"",
    "dev:renderer": "vite --host 127.0.0.1 --port 5173",
    "dev:main": "tsup electron-main/main.ts electron-main/preload.ts workers/task-worker.ts --format cjs --watch --out-dir dist-electron --external electron --sourcemap",
    "dev:electron": "wait-on tcp:5173 file:./dist-electron/electron-main/main.js && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "build": "npm run build:renderer && npm run build:main",
    "build:renderer": "vite build",
    "build:main": "tsup electron-main/main.ts electron-main/preload.ts workers/task-worker.ts --format cjs --out-dir dist-electron --external electron --sourcemap --clean",
    "preview": "vite preview",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win nsis",
    "lint": "tsc --noEmit",
    "test:smoke": "tsx --test tests/smoke.test.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "adm-zip": "^0.5.16",
    "clsx": "^2.1.1",
    "lucide-react": "^0.511.0",
    "pdf-lib": "^1.17.1",
    "pdf-poppler": "^0.2.3",
    "pdfjs-dist": "^4.4.168",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.33.5",
    "tesseract.js": "^6.0.1",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^32.2.7",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.2",
    "tsx": "^4.19.3",
    "tsup": "^8.3.5",
    "vite": "^5.4.11",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.codex.offlinepdftoolkit",
    "productName": "Offline PDF Toolkit",
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "assets",
        "to": "assets"
      }
    ],
    "asarUnpack": [
      "**/node_modules/pdf-poppler/**",
      "**/node_modules/tesseract.js/**",
      "**/node_modules/tesseract.js-core/**"
    ],
    "directories": {
      "buildResources": "assets",
      "output": "release"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  }
}
